# Copy to .env for local development.
#
# Start ingest stacks first:
#   sec-edgar-filings-to-pgvector  → ParadeDB/pgvector (edgar-pgvector) on localhost:5433
#   sec-edgar-filings-to-qdrant    → Qdrant (edgar-qdrant) on localhost:6333
#
# Native uvicorn: use localhost URLs below.
# docker compose (chat in Docker): defaults use host.docker.internal to reach those host ports.

PGUSER=postgres
PGPASSWORD=postgres
PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=edgar

DEFAULT_VECTOR_STORE=pgvector
PGSEARCH_ENABLED=true
QDRANTSEARCH_ENABLED=true
SEARCH_TOP_K=25
HYBRID_RETRIEVAL_TOP_K=50

OLLAMA_BASE_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=filing_chunks
QDRANT_DENSE_VECTOR=dense
QDRANT_BM25_VECTOR=content-bm25
QDRANT_BM25_MODEL=Qdrant/bm25

SERVER_PORT=8095
