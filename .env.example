# Copy to .env for local development with Docker vector stores.
# Matches application-docker.yml from the Java UI project.

PGUSER=postgres
PGPASSWORD=postgres
PG_HOST=localhost
PG_PORT=5433
PG_DATABASE=edgar

DEFAULT_VECTOR_STORE=pgvector
PGSEARCH_ENABLED=true
SEARCH_TOP_K=25
HYBRID_RETRIEVAL_TOP_K=50

OLLAMA_BASE_URL=http://localhost:11434
QDRANT_URL=http://localhost:16333
